{
  "name": "vega-api",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "admin-ui"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build:ui && wrangler deploy",
    "start": "wrangler dev",
    "test": "vitest",
    "build:ui": "npm -w admin-ui run build",
    "dev:ui": "npm -w admin-ui run dev",
    "db:migrate": "wrangler d1 migrations apply vega-api-db",
    "db:migrate:local": "wrangler d1 migrations apply vega-api-db --local"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@cloudflare/workers-types": "^4.20260611.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "~3.2.0",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "hono": "^4.12.25"
  }
}
